@Library('sharedlib@main')_
pipeline {
    agent {
        label 'mynode'
    }
    environment {
        maven = tool name: 'maven', type: 'maven'
        sonar_scanner = tool name: 'sonarscanner', type: 'hudson.plugins.sonar.SonarRunnerInstallation'
    }

 parameters {
  booleanParam defaultValue: true, name: 'Runsonar'
}
   stages {
        stage('git checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/doitomkar123/java-hello-world.git'
            }
        }
        stage ('Sonarqube') {
            when {
                expression {params.Runsonar == true}
            }
            steps {
                withSonarQubeEnv('sonar-server'){
                    sh "${sonar_scanner}/bin/sonar-scanner"
                }
            }
        }
        stage ('Unit test & artifacts') {
            steps {
                // sh "${maven}/bin/mvn clean install"
                mavenbuild()
            }
        }
        stage ('Deploy') {
            steps {
                sh """
                    export JENKINS_NODE_COOKIE=dontKillMe
                    chmod +x run.sh
                    bash run.sh
                """
            }
        }
    }
    post {
        always{
            publishHTML([allowMissing: false, alwaysLinkToLastBuild: false, icon: '', keepAll: false, reportDir: 'target/site/jacoco/', reportFiles: 'index.html', reportName: 'Code Coverage Report', reportTitles: '', useWrapperFileDirectly: true])
            junit 'target/surefire-reports/*.xml'
            
            mail bcc: '', body: """${JOB_NAME} - BUILD #${BUILD_NUMBER} - ${currentBuild.currentResult}

Check logs - ${RUN_DISPLAY_URL}

Sent from declarative piepline""", cc: '', from: '', replyTo: '', subject: "${JOB_NAME} - BUILD #${BUILD_NUMBER} - ${currentBuild.currentResult}", to: 'doitomkar123@gmail.com'
        }
    }
}
